{
  "name": "gearbrain",
  "version": "1.2.5",
  "description": "AI Diagnostika – Ford Transit EU",
  "main": "electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "test": "node tests/obd.test.js && node tests/cloud.test.js && node tests/rag.test.js && node tests/validation.test.js && node tests/validation-standalone.test.js"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "serialport": "^12.0.0",
    "electron-updater": "^6.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "cz.gearbrain.app",
    "productName": "GearBrain",
    "copyright": "Copyright © 2025",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerLanguages": [
        "cs-CZ",
        "en-US"
      ],
      "language": "1029",
      "deleteAppDataOnUninstall": false
    },
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "davidsekal-stack",
      "repo": "GearBrain",
      "releaseType": "release"
    }
  }
}